{
  "/flexi-options": {
    "target": "https://appprot.whapruebas.com/index.php/wp-json",
    "secure": true,
    "changeOrigin": true,
    "onProxyReq": function(proxyReq: any) {
      proxyReq.setHeader('Origin', 'https://appprot.whapruebas.com');
      proxyReq.setHeader('Referer', 'https://appprot.whapruebas.com/');
    },
    "logLevel": "debug"
  },
  "/proxy-wc/main": {
    "target": "https://appprot.whapruebas.com",
    "secure": true,
    "changeOrigin": true,
    "pathRewrite": {
      "^/proxy-wc/main": ""
    },
    "logLevel": "debug"
  },
  "/proxy-wc/test": {
    "target": "https://appprot.whapruebas.com/test",
    "secure": true,
    "changeOrigin": true,
    "pathRewrite": {
      "^/proxy-wc/test": ""
    },
    "logLevel": "debug"
  },
  "/proxy-wc/test2": {
    "target": "https://appprot.whapruebas.com/test2",
    "secure": true,
    "changeOrigin": true,
    "pathRewrite": {
      "^/proxy-wc/test2": ""
    },
    "logLevel": "debug"
  }
}
